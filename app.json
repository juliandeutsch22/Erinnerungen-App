{
  "expo": {
    "name": "Stoa",
    "slug": "stille",
    "version": "1.23.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stille",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.julian.stille",
      "buildNumber": "45",
      "icon": {
        "light": "./assets/images/icon.png",
        "dark": "./assets/images/icon-dark.png",
        "tinted": "./assets/images/icon-tinted.png"
      },
      "infoPlist": {
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true
      }
    },
    "android": {
      "package": "app.julian.stille",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1F4467",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#F4F1E8",
          "dark": {
            "backgroundColor": "#0B0E13"
          }
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      [
        "expo-calendar",
        {
          "calendarPermission": "Stoa zeigt deine Kalender-Termine neben deinen Aufgaben an — alles bleibt auf dem Gerät.",
          "remindersPermission": "Stoa liest deine Apple-Erinnerungen nur für den einmaligen Import — alles bleibt auf dem Gerät."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Stoa nutzt Face ID nur, um die App auf diesem Gerät zu entsperren."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Stoa nutzt das Mikrofon nur, um dein Diktat auf dem Gerät in Text umzuwandeln.",
          "speechRecognitionPermission": "Stoa wandelt deine Sprache auf dem Gerät in Text um — es verlässt das iPhone nicht."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
